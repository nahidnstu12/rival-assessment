# Frontend Patterns

## URL is the only filter state

```ts
// ✅ read from URL, write to URL
const params = useSearchParams();
const status = params.get("status") ?? "";

// ❌ never store filters in useState
const [status, setStatus] = useState("");
```

## React Query key = URL params object

```ts
// ✅ key changes automatically with URL → cache per combination
useQuery({
  queryKey: ["tasks", { status, search, sort, order, page }],
  queryFn: () => tasksApi.list({ status, search, sort, order, page }),
  placeholderData: keepPreviousData,
});

// ❌ never use a static key for a filtered list
useQuery({ queryKey: ["tasks"], queryFn: getTasks });
```

## API client — always include credentials

```ts
// lib/api.ts
const res = await fetch(`/api${path}`, {
  credentials: "include", // sends httpOnly cookie
  headers: { "Content-Type": "application/json" },
  ...options,
});
if (res.status === 401) { router.push("/login"); return; }
if (!res.ok) {
  const body = await res.json();
  throw new Error(body.error?.message ?? "Request failed");
}
return res.json();
```

## Form — RHF + Zod, always disable while pending

```tsx
// ✅
const form = useForm<TaskFormValues>({ resolver: zodResolver(taskSchema) });
const { isPending } = useMutation(...);
<Button type="submit" disabled={isPending}>
  {isPending ? <Spinner /> : "Save"}
</Button>
<p className="text-red-500 text-sm">{form.formState.errors.title?.message}</p>
```

## Changing filter resets page to 1

```ts
function setParam(key: string, value: string | null) {
  const next = new URLSearchParams(params.toString());
  value ? next.set(key, value) : next.delete(key);
  if (key !== "page") next.set("page", "1"); // always reset
  router.replace(`${pathname}?${next.toString()}`);
}
```

## UX states — every list must handle all three

```tsx
if (query.isLoading) return <TaskSkeleton />;
if (query.isError) return <ErrorState onRetry={query.refetch} />;
if (!query.data?.data.length) return <EmptyState />;
return <TaskTable tasks={query.data.data} />;
```
